{
  "name": "foodclub-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "npm run db:migrate && node dist/main",
    "start:prod:init": "sh scripts/start-with-init.sh",
    "db:migrate": "npx sequelize-cli db:migrate --config src/infrastructure/database/config.js --env production",
    "db:seed": "npx sequelize-cli db:seed:all --config src/infrastructure/database/config.js --env production",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all --config src/infrastructure/database/config.js --env production",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r ts-node/register node_modules/jest/bin/jest.js --runInBand",
    "prepare": "husky"
  },
  "dependencies": {
    "@azure/identity": "^4.3.0",
    "@azure/storage-blob": "^12.28.0",
    "@aws-sdk/client-cloudwatch": "^3.908.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.908.0",
    "@aws-sdk/client-s3": "^3.908.0",
    "@aws-sdk/s3-request-presigner": "^3.908.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/sequelize": "^10.0.0",
    "@nestjs/swagger": "^7.3.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.5.0",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.2",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.1",
    "sequelize-cli": "^6.6.3",
    "sequelize-typescript": "^2.1.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.3",
    "chokidar": "3.6.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  },
  "overrides": {
    "chokidar": "3.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write",
      "npm run test -- --bail --findRelatedTests"
    ]
  }
}
