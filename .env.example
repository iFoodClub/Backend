# Database Configuration
DB_HOST=your_database_host
DB_PORT=your_database_port
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password
DB_DATABASE=your_database_name
# Postgres local: false. Nuvem (Render etc.): omita ou true
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=3600

# Server Configuration
PORT=3000
NODE_ENV=development

# Azure Blob Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=imagensfoodclub
AZURE_STORAGE_ACCOUNT_KEY=

# Se vazio, o código monta https://<account>.blob.core.windows.net automaticamente.
AZURE_STORAGE_ACCOUNT_URL=

# Container padrão usado quando não existe um container com o mesmo nome da pasta.
AZURE_STORAGE_CONTAINER_NAME=app-uploads

# Opcional: preencha apenas se o Container App estiver usando User Assigned Managed Identity.
# Se a identidade for System Assigned, deixe vazio.
AZURE_CLIENT_ID=

# URL pública da aplicação usada pelos clientes para acessar os uploads.
API_PUBLIC_BASE_URL=https://api-foodclub-hml.politemushroom-8b6971df.canadacentral.azurecontainerapps.io/

# AWS S3 Configuration (legado, usado apenas em integrações antigas)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=your_aws_region
AWS_S3_BUCKET_NAME=your_aws_bucket_name

# AWS CloudWatch Configuration (credenciais separadas)
AWS_ACCESS_KEY_ID_CLOUDWATCH=your_aws_access_key_id_for_cloudwatch
AWS_SECRET_ACCESS_KEY_CLOUDWATCH=your_aws_secret_access_key_for_cloudwatch
CLOUDWATCH_LOG_GROUP=/aws/foodclub/backend
CLOUDWATCH_NAMESPACE=FoodClub/Backend

# MongoDB Atlas
DOCUMENTDB_URI=your_mongodb_atlas_connection_string
