# Database Configuration
DB_HOST=your_database_host
DB_PORT=your_database_port
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password
DB_DATABASE=your_database_name
# Postgres local: false. Nuvem (Render etc.): omita ou true
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=3600

# Server Configuration
PORT=3000
NODE_ENV=development

# Azure Blob Storage Configuration
# Obrigatório: nome da storage account.
# O serviço monta o URL automaticamente se AZURE_STORAGE_ACCOUNT_URL não estiver definido.
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name

# Opcional: sobrescreve o endpoint da storage account.
# Em geral, deixe vazio no ambiente local e em produção use apenas se precisar de um endpoint customizado.
AZURE_STORAGE_ACCOUNT_URL=https://your_storage_account_name.blob.core.windows.net

# Container padrão usado para uploads.
AZURE_STORAGE_CONTAINER_NAME=app-uploads

# Opcional: necessário apenas se você estiver usando User Assigned Managed Identity.
AZURE_CLIENT_ID=your_user_assigned_managed_identity_client_id

# Base pública da API usada para montar URLs retornadas no upload.
API_PUBLIC_BASE_URL=http://localhost:3000

# AWS S3 Configuration (legado, usado apenas em integrações antigas)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=your_aws_region
AWS_S3_BUCKET_NAME=your_aws_bucket_name

# AWS CloudWatch Configuration (credenciais separadas)
AWS_ACCESS_KEY_ID_CLOUDWATCH=your_aws_access_key_id_for_cloudwatch
AWS_SECRET_ACCESS_KEY_CLOUDWATCH=your_aws_secret_access_key_for_cloudwatch
CLOUDWATCH_LOG_GROUP=/aws/foodclub/backend
CLOUDWATCH_NAMESPACE=FoodClub/Backend

# MongoDB Atlas
DOCUMENTDB_URI=your_mongodb_atlas_connection_string
