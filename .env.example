# Database Configuration
DB_HOST=your_database_host
DB_PORT=your_database_port
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password
DB_DATABASE=your_database_name

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=3600

# Server Configuration
PORT=3000
NODE_ENV=development

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=your_aws_region
AWS_S3_BUCKET_NAME=your_aws_bucket_name
AWS_SECRET_ACCESS_KEY_CLOUDWATCH=your_aws_secret_access_key_for_cloudwatch
AWS_ACCESS_KEY_ID_CLOUDWATCH=your_aws_access_key_id_for_cloudwatch
CLOUDWATCH_NAMESPACE=your_cloudwatch_namespace
CLOUDWATCH_LOG_GROUP=/aws/your_log_group/name